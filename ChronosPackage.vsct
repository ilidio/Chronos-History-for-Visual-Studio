  <Extern href="stdidcmd.h"/>
  <Extern href="vsshlids.h"/>

  <Commands package="guidChronosPackage">
    <Menus>
      <Menu guid="guidChronosPackageCmdSet" id="ChronosSubMenu" priority="0x0100" type="Menu">
        <Parent guid="guidChronosPackageCmdSet" id="ChronosGroup" />
        <Strings>
          <ButtonText>Chronos History</ButtonText>
        </Strings>
      </Menu>
    </Menus>

    <Groups>
      <!-- Main group that goes into VS context menus -->
      <Group guid="guidChronosPackageCmdSet" id="ChronosGroup" priority="0x0600">
        <Parent guid="guidSHLMainMenu" id="IDM_VS_CTXT_ITEMNODE"/>
      </Group>

      <!-- Groups inside our sub-menu for organization -->
      <Group guid="guidChronosPackageCmdSet" id="LocalHistoryGroup" priority="0x0100">
        <Parent guid="guidChronosPackageCmdSet" id="ChronosSubMenu"/>
      </Group>
      <Group guid="guidChronosPackageCmdSet" id="GitHistoryGroup" priority="0x0200">
        <Parent guid="guidChronosPackageCmdSet" id="ChronosSubMenu"/>
      </Group>
      <Group guid="guidChronosPackageCmdSet" id="ProjectHistoryGroup" priority="0x0300">
        <Parent guid="guidChronosPackageCmdSet" id="ChronosSubMenu"/>
      </Group>
      <Group guid="guidChronosPackageCmdSet" id="UtilityGroup" priority="0x0400">
        <Parent guid="guidChronosPackageCmdSet" id="ChronosSubMenu"/>
      </Group>
      <Group guid="guidChronosPackageCmdSet" id="TransferGroup" priority="0x0500">
        <Parent guid="guidChronosPackageCmdSet" id="ChronosSubMenu"/>
      </Group>
    </Groups>

    <Buttons>
      <!-- Local History Section -->
      <Button guid="guidChronosPackageCmdSet" id="ShowHistoryCommandId" priority="0x0100" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="LocalHistoryGroup" />
        <Strings>
          <ButtonText>Show History</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidChronosPackageCmdSet" id="ShowHistorySelectionCommandId" priority="0x0200" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="LocalHistoryGroup" />
        <Strings>
          <ButtonText>Show History for Selection</ButtonText>
        </Strings>
      </Button>

      <!-- Git History Section -->
      <Button guid="guidChronosPackageCmdSet" id="ShowGitHistoryCommandId" priority="0x0100" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="GitHistoryGroup" />
        <Strings>
          <ButtonText>Show Git History</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidChronosPackageCmdSet" id="GitHistorySelectionCommandId" priority="0x0200" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="GitHistoryGroup" />
        <Strings>
          <ButtonText>Git History for Selection</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidChronosPackageCmdSet" id="CompareWithBranchCommandId" priority="0x0300" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="GitHistoryGroup" />
        <Strings>
          <ButtonText>Compare with Branch...</ButtonText>
        </Strings>
      </Button>

      <!-- Project History Section -->
      <Button guid="guidChronosPackageCmdSet" id="ShowProjectHistoryCommandId" priority="0x0100" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="ProjectHistoryGroup" />
        <Strings>
          <ButtonText>Show Project History</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidChronosPackageCmdSet" id="ShowHistoryGraphCommandId" priority="0x0200" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="ProjectHistoryGroup" />
        <Strings>
          <ButtonText>Show History Graph</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidChronosPackageCmdSet" id="ShowRecentChangesCommandId" priority="0x0300" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="ProjectHistoryGroup" />
        <Strings>
          <ButtonText>Show Recent Changes</ButtonText>
        </Strings>
      </Button>

      <!-- Utility Section -->
      <Button guid="guidChronosPackageCmdSet" id="ToggleHeatmapCommandId" priority="0x0100" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="UtilityGroup" />
        <Strings>
          <ButtonText>Toggle Code Heatmap</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidChronosPackageCmdSet" id="PutLabelCommandId" priority="0x0200" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="UtilityGroup" />
        <Strings>
          <ButtonText>Put Label</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidChronosPackageCmdSet" id="GenerateCommitMessageCommandId" priority="0x0300" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="UtilityGroup" />
        <Strings>
          <ButtonText>Generate Commit Message</ButtonText>
        </Strings>
      </Button>

      <!-- Transfer Section -->
      <Button guid="guidChronosPackageCmdSet" id="ExportHistoryCommandId" priority="0x0100" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="TransferGroup" />
        <Strings>
          <ButtonText>Export History</ButtonText>
        </Strings>
      </Button>
      <Button guid="guidChronosPackageCmdSet" id="ImportHistoryCommandId" priority="0x0200" type="Button">
        <Parent guid="guidChronosPackageCmdSet" id="TransferGroup" />
        <Strings>
          <ButtonText>Import History</ButtonText>
        </Strings>
      </Button>
    </Buttons>
  </Commands>

