    <!-- Placement in Code Editor -->
    <CommandPlacement guid="guidChronosPackageCmdSet" id="ChronosGroup" priority="0x0600">
      <Parent guid="guidSHLMainMenu" id="IDM_VS_CTXT_CODEWIN"/>
    </CommandPlacement>
  </CommandPlacements>

